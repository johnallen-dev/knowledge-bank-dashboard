ANTHROPIC_API_KEY=sk-ant-your-key-here

# Notion OAuth (recommended — connect via browser login)
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret

# OR: Notion Internal Token (manual alternative)
# NOTION_TOKEN=secret_your-notion-token-here

# Optional: limit search to specific databases (leave blank to search all shared pages)
NOTION_DATABASE_IDS=

NEXT_PUBLIC_PROPERTY_NAME=Knowledge Bank
NEXT_PUBLIC_APP_URL=http://localhost:3000
DB_PATH=./data/knowledge-bank.db
